#!/bin/bash
set -e

echo "🍰 Muffin Configuration Builder"
echo "================================"

echo "Validating configuration..."
if [ ! -f "muffin.toml" ]; then
    echo "Error: muffin.toml not found"
    exit 1
fi

echo "Generating .mcfg file..."
mkdir -p build
cat > build/.mcfg << EOF
# Muffin Configuration
# Generated at $(date)
EOF

echo "✓ .mcfg generated successfully"