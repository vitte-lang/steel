    <item>
      <title>Cookbook</title>
      <link>http://localhost/cookbook/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost/cookbook/</guid>
      <description>&lt;h1 id=&#34;cookbook&#34;&gt;Cookbook&lt;/h1&gt;&#xA;&lt;p&gt;Recettes pratiques basées sur les exemples du repo.&lt;/p&gt;&#xA;&lt;p&gt;&lt;img src=&#34;http://localhost/assets/img/cookbook.svg&#34; alt=&#34;Cookbook run&#34;&gt;&lt;/p&gt;&#xA;&lt;h2 id=&#34;c-app-single-bake&#34;&gt;C app (single bake)&lt;/h2&gt;&#xA;&lt;p&gt;Exemple :&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;config: &lt;code&gt;examples/gcc/MuffinConfig.muf&lt;/code&gt;&lt;/li&gt;&#xA;&lt;li&gt;source: &lt;code&gt;examples/gcc/app/main.c&lt;/code&gt;&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;muffin run --root examples/gcc --file MuffinConfig.muf --bake app&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;Dry-run :&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;muffin run --root examples/gcc --file MuffinConfig.muf --bake app --print&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;Outputs :&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;code&gt;examples/gcc/target/out/app&lt;/code&gt;&lt;/li&gt;&#xA;&lt;li&gt;&lt;code&gt;examples/gcc/target/muffin_run_*.mff&lt;/code&gt;&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;library--app-deps&#34;&gt;Library + app (deps)&lt;/h2&gt;&#xA;&lt;p&gt;Exemple multi-bakes :&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;config: &lt;code&gt;examples/gcc/MuffinConfig_multi.muf&lt;/code&gt;&lt;/li&gt;&#xA;&lt;li&gt;lib: &lt;code&gt;examples/gcc/lib/lib.c&lt;/code&gt;&lt;/li&gt;&#xA;&lt;li&gt;app: &lt;code&gt;examples/gcc/app/main.c&lt;/code&gt;&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;muffin run --root examples/gcc --file MuffinConfig_multi.muf --bake app&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;Build tout :&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;muffin run --root examples/gcc --file MuffinConfig_multi.muf --all&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;Outputs :&lt;/p&gt;</description>
    </item>
