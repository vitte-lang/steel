    <item>
      <title>Quickstart</title>
      <link>http://localhost/quickstart/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost/quickstart/</guid>
      <description>&lt;h1 id=&#34;quickstart&#34;&gt;Quickstart&lt;/h1&gt;&#xA;&lt;p&gt;Chemin minimal pour un projet C simple avec MUF v4.1.&lt;/p&gt;&#xA;&lt;p&gt;&lt;img src=&#34;http://localhost/assets/img/quickstart.svg&#34; alt=&#34;Quickstart run&#34;&gt;&lt;/p&gt;&#xA;&lt;p&gt;&lt;strong&gt;MUF v4.1&lt;/strong&gt;&lt;/p&gt;&#xA;&lt;h2 id=&#34;install&#34;&gt;Install&lt;/h2&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;cargo install --path . --force&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id=&#34;build-config-muf-v41&#34;&gt;Build config (MUF v4.1)&lt;/h2&gt;&#xA;&lt;p&gt;Creer &lt;code&gt;MuffinConfig.muf&lt;/code&gt; a la racine :&lt;/p&gt;&#xA;&lt;pre tabindex=&#34;0&#34;&gt;&lt;code class=&#34;language-muf&#34; data-lang=&#34;muf&#34;&gt;!muf 4&#xA;&#xA;[workspace]&#xA;  .set name &amp;#34;app&amp;#34;&#xA;  .set target_dir &amp;#34;target&amp;#34;&#xA;  .set profile &amp;#34;debug&amp;#34;&#xA;..&#xA;&#xA;[profile debug]&#xA;  .set opt 0&#xA;  .set debug 1&#xA;  .set ndebug 0&#xA;..&#xA;&#xA;[tool gcc]&#xA;  .exec &amp;#34;gcc&amp;#34;&#xA;..&#xA;&#xA;[bake app]&#xA;  .make c_src cglob &amp;#34;**/*.c&amp;#34;&#xA;  [run gcc]&#xA;    .takes c_src as &amp;#34;@args&amp;#34;&#xA;    .set &amp;#34;-std=c17&amp;#34; 1&#xA;    .set &amp;#34;-O${opt}&amp;#34; 1&#xA;    .set &amp;#34;-g&amp;#34; &amp;#34;${debug}&amp;#34;&#xA;    .set &amp;#34;-DNDEBUG&amp;#34; &amp;#34;${ndebug}&amp;#34;&#xA;    .set &amp;#34;-Wall&amp;#34; 1&#xA;    .set &amp;#34;-Wextra&amp;#34; 1&#xA;    .emits exe as &amp;#34;-o&amp;#34;&#xA;  ..&#xA;  .output exe &amp;#34;target/out/app&amp;#34;&#xA;..&#xA;&#xA;[export]&#xA;  .ref app&#xA;..&#xA;&lt;/code&gt;&lt;/pre&gt;&lt;h2 id=&#34;run&#34;&gt;Run&lt;/h2&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;muffin run --root . --file MuffinConfig.muf&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;Dry-run :&lt;/p&gt;</description>
    </item>
