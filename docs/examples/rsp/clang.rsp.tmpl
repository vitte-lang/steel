# ============================================================================
# Muffin Toolchain — clang.rsp.tmpl (MAX)
# Path: /docs/examples/rsp/clang.rsp.tmpl
#
# Purpose:
# - Response-file template for clang/clang++ compile (and optionally link).
# - Avoids command line length limits (esp. on Windows).
# - Centralizes flags generation (target/profile/defines/includes).
#
# Template language (doc-oriented):
# - {mode}           => "compile" | "link" | "preprocess" | "assemble"
# - {lang}           => "c" | "cxx" | "objc" | "objcxx" | "asm"
# - {target}         => target triple (optional)
# - {sysroot}        => sysroot path (optional)
# - {opt}            => optimization flags (e.g. -O0/-O2/-O3)
# - {debug}          => debug flags (e.g. -g)
# - {warnings}       => warnings set (optional)
# - {std}            => language standard flag (optional)
# - {defines}        => preprocessor defines (one per line, already prefixed -D)
# - {includes}       => include dirs (one per line, already prefixed -I)
# - {system_includes}=> system include dirs (-isystem ...)
# - {cflags}         => extra C/C++ flags (one per line)
# - {ldflags}        => extra link flags (one per line)
# - {libs}           => libraries (-lfoo / path/to/libfoo.a) (one per line)
# - {inputs}         => source/object inputs (one per line)
# - {output}         => output file path (-o ...)
# - {depfile}        => dependency file path (optional)
# - {pch}            => precompiled header (optional)
# - {extra}          => extra args (optional)
#
# Notes:
# - clang accepts response files: clang @file.rsp
# - Each non-empty line is treated as whitespace-separated args; keep one arg
#   per line for maximum portability.
# ============================================================================

# ----------------------------------------------------------------------------
# 0) Mode selection (driver may ignore comment blocks; present for clarity)
# ----------------------------------------------------------------------------
# mode: {mode}
# lang: {lang}

# ----------------------------------------------------------------------------
# 1) Target / sysroot (optional)
# ----------------------------------------------------------------------------
{target}
{sysroot}

# ----------------------------------------------------------------------------
# 2) Language & standard
# ----------------------------------------------------------------------------
# If your driver expands {std} to "-std=c17" / "-std=c++20" etc.
{std}

# ----------------------------------------------------------------------------
# 3) Core compilation flags
# ----------------------------------------------------------------------------
{opt}
{debug}

# Dependency generation (optional; driver emits only if set)
{depfile}

# Precompiled header (optional)
{pch}

# Warnings (optional)
{warnings}

# ----------------------------------------------------------------------------
# 4) Defines and include paths
# ----------------------------------------------------------------------------
{defines}
{includes}
{system_includes}

# ----------------------------------------------------------------------------
# 5) Extra compile flags
# ----------------------------------------------------------------------------
{cflags}

# ----------------------------------------------------------------------------
# 6) Inputs
# ----------------------------------------------------------------------------
{inputs}

# ----------------------------------------------------------------------------
# 7) Output
# ----------------------------------------------------------------------------
{output}

# ----------------------------------------------------------------------------
# 8) Link stage (only used if mode=link)
# ----------------------------------------------------------------------------
{ldflags}
{libs}

# ----------------------------------------------------------------------------
# 9) Extra args
# ----------------------------------------------------------------------------
{extra}
